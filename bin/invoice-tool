<script>
let itemCount = 1;
function addItem() {
  const i = itemCount++;
  const container = document.getElementById('items');
  const row = document.createElement('div');
  row.className = 'item-row';

  const fields = [
    {name: `item_name_${i}`, placeholder: 'resource', cls: ''},
    {name: `item_description_${i}`, placeholder: 'description', cls: ''},
    {name: `item_usage_${i}`, placeholder: 'usage', cls: ''},
    {name: `item_amount_${i}`, placeholder: '0.00', cls: 'amount-col', type: 'number'}
  ];

  fields.forEach(f => {
    const div = document.createElement('div');
    if (f.cls) div.className = f.cls;
    const input = document.createElement('input');
    input.type = f.type || 'text';
    input.name = f.name;
    input.placeholder = f.placeholder;
    if (f.type === 'number') input.step = '0.01';
    div.appendChild(input);
    row.appendChild(div);
  });

  const removeDiv = document.createElement('div');
  removeDiv.className = 'remove-col';
  const removeBtn = document.createElement('button');
  removeBtn.type = 'button';
  removeBtn.textContent = '\u00D7';
  removeBtn.addEventListener('click', function() { removeItem(this); });
  removeDiv.appendChild(removeBtn);
  row.appendChild(removeDiv);

  container.appendChild(row);
}
function removeItem(btn) {
  const row = btn.closest('.item-row');
  if (document.querySelectorAll('.item-row').length > 1) {
    row.remove();
  }
}
</script>
</body>
</html>
HTML

port = Integer(ENV["PORT"] || 9872)

server = WEBrick::HTTPServer.new(Port: port, Logger: WEBrick::Log.new($stdout, WEBrick::Log::INFO), AccessLog: [])

server.mount_proc "/" do |req, res|
  if req.request_method == "GET"
    res.content_type = "text/html"
    res.body = HTML_FORM
  else
    res.status = 405
  end
end

server.mount_proc "/generate" do |req, res|
  if req.request_method == "POST"
    params = parse_form(req.body || "")
    pdf_data = generate_pdf(params)
    res.content_type = "application/pdf"
    res["Content-Disposition"] = "inline; filename=\"invoice.pdf\""
    res.body = pdf_data
  else
    res.status = 405
  end
end

trap("INT") { server.shutdown }
trap("TERM") { server.shutdown }

puts "Invoice generator running at http://localhost:#{port}"
server.start
