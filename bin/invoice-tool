  .btn-primary { background: #2563eb; color: #fff; font-size: 1rem; padding: .75rem 2rem; }
  .btn-primary:hover { background: #1d4ed8; }
  .btn-secondary { background: #e5e7eb; color: #374151; }
  .btn-secondary:hover { background: #d1d5db; }
  .actions { margin-top: 1.5rem; display: flex; gap: .75rem; justify-content: flex-end; }
  .checkbox-row { display: flex; align-items: center; gap: .5rem; margin-bottom: .75rem; }
