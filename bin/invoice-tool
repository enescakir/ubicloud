#!/usr/bin/env ruby
# frozen_string_literal: true

# Standalone invoice PDF generator tool.
# Usage: ruby bin/invoice-tool
# Then open http://localhost:9872 in your browser.

require "webrick"
require "prawn"
require "prawn/table"
require "json"
require "date"
require "cgi"

ASSETS_DIR = File.expand_path("../../assets", __FILE__)
PUBLIC_DIR = File.expand_path("../../public", __FILE__)

ISSUERS = {
  "bv" => {
    name: "Ubicloud B.V.",
    address: "Turfschip 267",
    country: "Netherlands",
    city: "Amstelveen",
    postal_code: "1186 XK",
    tax_id: "NL864651442B01",
    trade_id: "88492729"
  },
  "inc" => {
    name: "Ubicloud Inc.",
    address: "310 Santa Ana Avenue",
    country: "United States",
    city: "San Francisco",
    state: "CA",
    postal_code: "94127"
  }
}

BANK_TRANSFER_INFO = {
  "bv" => {
    "Beneficiary" => "Ubicloud B.V.",
    "IBAN" => "NL30REVO6759811127",
    "BIC" => "REVONL22",
    "Intermediary BIC" => "CHASGB2L",
    "Beneficiary address" => "Turfschip, 267, 1186XK, Amstelveen, Netherlands",
    "Bank/Payment institution" => "Revolut Bank UAB",
    "Bank address" => "Barbara Strozzilaan 201, 1083 HN, Amsterdam, Netherlands"
  },
  "inc" => {
    "Beneficiary" => "Ubicloud Inc.",
    "Beneficiary address" => "310 Santa Ana Ave, San Francisco, CA 94127",
    "ABA/Routing number" => "121145349",
    "Account number" => "974842159957503",
    "Bank/Payment institution" => "Column NA - Brex",
    "Bank address" => "1 Letterman Drive Building A, Suite A4-700, San Francisco, CA 94129"
  }
}

def parse_form(body)
  params = {}
  body.split("&").each do |pair|
    key, value = pair.split("=", 2)
    params[CGI.unescape(key)] = CGI.unescape(value || "")
  end
  params
end

def parse_items(params)
  items = []
  i = 0
  loop do
    name = params["item_name_#{i}"]
    break unless name && !name.empty?
    items << {
      name: name,
      description: params["item_description_#{i}"] || "",
      usage: params["item_usage_#{i}"] || "",
      amount: params["item_amount_#{i}"].to_f
    }
    i += 1
  end
  items
end

def currency_symbol(currency)
  currency == "EUR" ? "\u20AC" : "$"
end

def format_money(amount, currency)
  whole, decimal = ("%.2f" % amount).split(".")
  whole_with_sep = whole.gsub(/(\d)(?=(\d{3})+(?!\d))/, '\1,')
  "#{currency_symbol(currency)}#{whole_with_sep}.#{decimal}"
end

def generate_pdf(params)
  issuer_key = params["issuer"] || "inc"
  issuer = ISSUERS[issuer_key]
  currency = params["currency"] || "USD"
  items = parse_items(params)
  include_bank = params["bank_transfer"] == "on"
  tax_label = (params["tax_label"] || "").strip
  tax_label = "VAT" if tax_label.empty?
  tax_ratio_str = (params["tax_ratio"] || "").strip
  tax_text = (params["tax_text"] || "").strip
  invoice_number = (params["invoice_number"] || "").strip
  note = (params["note"] || "").strip

  subtotal = items.sum { |it| it[:amount] }
  tax_amount = 0.0
  tax_display = nil
  tax_display_value = nil

  if !tax_text.empty?
    tax_display = "#{tax_label}:"
    tax_display_value = tax_text
  elsif !tax_ratio_str.empty?
    tax_ratio = tax_ratio_str.to_f
    tax_amount = (subtotal * tax_ratio / 100.0).round(2)
    tax_display = "#{tax_label} (#{tax_ratio}%)"
  end

  total = subtotal + tax_amount

  pdf = Prawn::Document.new(
    page_size: "A4",
    page_layout: :portrait,
    info: {Title: "Invoice", Creator: "Ubicloud", CreationDate: Time.now}
  )

  pdf.font_families.update(
    "BeVietnamPro" => {
      normal: File.join(ASSETS_DIR, "font/BeVietnamPro/Regular.ttf"),
      semibold: File.join(ASSETS_DIR, "font/BeVietnamPro/SemiBold.ttf")
    }
  )
  pdf.font "BeVietnamPro"

  column_width = (pdf.bounds.width / 2) - 10
  right_column_x = column_width + 20
  dark_gray = "1F2937"
  light_gray = "6B7280"

  pdf.fill_color light_gray

  # Row 1, Left: Logo + issuer
  row_y = pdf.bounds.top
  row = pdf.bounding_box([0, row_y], width: column_width) do
    logo_path = File.join(PUBLIC_DIR, "logo-primary.png")
    pdf.image logo_path, height: 25, position: :left
    pdf.move_down 10
    pdf.text issuer[:name], style: :semibold, color: dark_gray
    pdf.text "#{issuer[:address]},"
    location_parts = [issuer[:city], issuer[:state], issuer[:postal_code]].compact.reject(&:empty?)
    pdf.text "#{location_parts.join(", ")},"
    pdf.text issuer[:country]
    pdf.text "Tax ID: #{issuer[:tax_id]}" if issuer[:tax_id]
    pdf.text "CCI/KVK ID: #{issuer[:trade_id]}" if issuer[:trade_id]
  end

  # Row 1, Right: Invoice title
  invoice_title = params["invoice_title"].to_s.strip
  invoice_title = "Invoice" if invoice_title.empty?
  pdf.bounding_box([right_column_x, row_y], width: column_width) do
    pdf.text invoice_title, align: :right, style: :semibold, color: dark_gray, size: 18
    pdf.text "##{invoice_number}", align: :right unless invoice_number.empty?
  end
  pdf.move_down row.height.to_i - 20

  # Row 2, Left: Customer info
  row_y = pdf.cursor
  customer_name = params["customer_name"].to_s.strip
  customer_address = params["customer_address"].to_s.strip
  customer_tax_id = params["customer_tax_id"].to_s.strip
  row = pdf.bounding_box([0, row_y], width: column_width) do
    unless customer_name.empty?
      pdf.text "Bill to:", style: :semibold, color: dark_gray, size: 14
      pdf.text customer_name, style: :semibold, color: dark_gray, size: 14
      pdf.move_down 5
      customer_address.split("\n").each { |line| pdf.text line.strip }
      pdf.text "#{tax_label} ID: #{customer_tax_id}" unless customer_tax_id.empty?
    end
  end

  # Row 2, Right: Dates
  pdf.bounding_box([right_column_x, row_y], width: column_width) do
    right_data = []
    creation_date = params["creation_date"].to_s.strip
    due_date = params["due_date"].to_s.strip
    right_data << ["Invoice date:", creation_date] unless creation_date.empty?
    right_data << ["Due date:", due_date] unless due_date.empty?
    right_data << ["Note:", note] unless note.empty?
    unless right_data.empty?
      pdf.table(right_data, position: :right) do
        style(row(0..2).columns(0..2), padding: [2, 5, 2, 5], borders: [])
        style(column(0), align: :right, width: 90, text_wrap: :right, font_style: :semibold, text_color: dark_gray)
        style(column(1), align: :right)
      end
    end
  end
  pdf.move_down row.height.to_i - 20

  # Row 3: Items table
  has_usage = items.any? { |item| !item[:usage].empty? }
  if has_usage
    table_items = [["RESOURCE", "DESCRIPTION", "USAGE", "AMOUNT"]]
    colspan = 4
  else
    table_items = [["RESOURCE", "DESCRIPTION", "AMOUNT"]]
    colspan = 3
  end
  if items.empty?
    table_items << [{content: "No resources", colspan: colspan, align: :center, font_style: :semibold}]
  else
    items.each do |item|
      row_data = [item[:name], item[:description]]
      row_data << item[:usage] if has_usage
      row_data << format_money(item[:amount], currency)
      table_items << row_data
    end
  end
  pdf.table table_items, header: true, width: pdf.bounds.width, cell_style: {size: 9, border_color: "E5E7EB", borders: [], padding: [5, 6, 12, 6], valign: :center} do
    style(row(0), size: 12, font_style: :semibold, text_color: dark_gray, background_color: "F9FAFB")
    style(column(0), text_color: dark_gray)
    style(columns(-2..-1), align: :right)
    style(column(0), borders: [:left, :top, :bottom])
    style(column(-1), borders: [:right, :top, :bottom], width: 70)
    style(columns(1..-2), borders: [:top, :bottom])
  end
  pdf.move_down 10

  # Row 4: Totals
  totals = [["Subtotal:", format_money(subtotal, currency)]]
  if tax_display && tax_amount > 0
    totals << ["#{tax_display}:", format_money(tax_amount, currency)]
  elsif tax_display && tax_display_value
    totals << [tax_display, tax_display_value]
  end
  totals << ["Total:", format_money(total, currency)]
  pdf.table(totals, position: :right, cell_style: {padding: [2, 5, 2, 5], borders: []}) do
    style(column(0), align: :right, font_style: :semibold, text_color: dark_gray)
    style(column(1), align: :right)
  end

  # Bank transfer info
  if include_bank
    bank_info = BANK_TRANSFER_INFO[issuer_key]
    if bank_info
      pdf.move_down 60
      bank_rows = [
        [{content: "We kindly request you to remit the amount to:", colspan: 2, font_style: :semibold}],
        *bank_info.to_a
      ]
      pdf.table(bank_rows, position: :left) do
        style(row(0..-1).columns(0..1), padding: [2, 5, 2, 5], borders: [])
        style(column(0), align: :right, font_style: :semibold, text_color: dark_gray)
        style(column(1), align: :left)
        style(row(0), align: :left)
      end
    end
  end

  pdf.render
end

HTML_FORM = <<~'HTML'
<!DOCTYPE html>
<html lang="en">
