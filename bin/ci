#!/usr/bin/env ruby
# frozen_string_literal: true

require "time"
require "optparse"

options = {test_cases: ["vm"]}
OptionParser.new do |opts|
  opts.on("--test-cases TEST_CASES", Array, "List of test cases to run separated by comma") { |v| options[:test_cases] = v }
end.parse!

puts options
exit 0
